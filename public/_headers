# Cloudflare Pages static headers.
# Vite fingerprints every file under /assets/* (content hash in the
# filename), so those can be cached forever — a new deploy always ships
# new filenames. index.html (and any other root-level file) must NOT be
# cached long-term or users will get stuck on a stale build after a deploy.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable
/*.css
  Cache-Control: public, max-age=31536000, immutable

/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
